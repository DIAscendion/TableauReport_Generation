  <dashboards>

    <dashboard _.fcp.AccessibleZoneTabOrder.true...enable-sort-zone-taborder='true'
               name='1. Service Reliability &amp; Support'>
      <style />
      <size maxheight='900' maxwidth='1400' minheight='900' minwidth='1400' />
      <zones>
        <zone h='100000' id='100' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98000' id='101' param='vert' type-v2='layout-flow' w='98400' x='800' y='1000'>

            <!-- Row 1: KPI sheet — full width -->
            <zone h='15000' id='102' name='Service KPIs' w='98400' x='800' y='1000'>
              <zone-style>
                <format attr='border-color' value='#cccccc' />
                <format attr='border-style' value='solid' />
                <format attr='border-width' value='1' />
                <format attr='margin' value='4' />
              </zone-style>
            </zone>

            <!-- Row 2: two charts side by side -->
