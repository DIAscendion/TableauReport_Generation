    <!-- ── WORKSHEET 11: COST TO RESOLVE BY CATEGORY ─────────────────── -->
    <worksheet name='Cost to Resolve by Category'>
      <layout-options>
        <title><formatted-text><run fontsize='13'>Cost to Resolve by Category</run></formatted-text></title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Service_Reliability_Support_DS' name='federated.1A2B3C4D' />
          </datasources>
          <datasource-dependencies datasource='federated.1A2B3C4D'>
            <column caption='Support Category' datatype='string' name='[SUPPORT_CATEGORY]' role='dimension' type='nominal' />
            <column caption='Total Cost to Resolve' datatype='integer' name='[Calculation_TOTAL_COST]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([COST_TO_RESOLVE])' />
            </column>
            <column-instance column='[SUPPORT_CATEGORY]' derivation='None' name='[none:SUPPORT_CATEGORY:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_TOTAL_COST]' derivation='User' name='[usr:Calculation_TOTAL_COST:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view><breakdown value='auto' /></view>
            <mark class='Bar' />
            <style>
              <style-rule element='mark'>
                <format attr='mark-labels-show' value='true' />
                <format attr='mark-labels-cull' value='true' />
              </style-rule>
            </style>
          </pane>
        </panes>
        <rows>[federated.1A2B3C4D].[usr:Calculation_TOTAL_COST:qk]</rows>
        <cols>[federated.1A2B3C4D].[none:SUPPORT_CATEGORY:nk]</cols>
      </table>
      <simple-id uuid='{AA00000B-0000-0000-0000-00000000000B}' />
    </worksheet>

    <!-- ── WORKSHEET 12: ROOT CAUSE ANALYSIS ─────────────────────────── -->
    <worksheet name='Root Cause Analysis'>
      <layout-options>
        <title><formatted-text><run fontsize='13'>Root Cause Analysis</run></formatted-text></title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Service_Reliability_Support_DS' name='federated.1A2B3C4D' />
          </datasources>
          <datasource-dependencies datasource='federated.1A2B3C4D'>
            <column caption='Root Cause Category' datatype='string' name='[ROOT_CAUSE_CATEGORY]' role='dimension' type='nominal' />
            <column caption='Total Activities' datatype='integer' name='[Calculation_TOTAL_ACTIVITIES]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT([SUPPORT_ACTIVITY_ID])' />
            </column>
            <column-instance column='[ROOT_CAUSE_CATEGORY]' derivation='None' name='[none:ROOT_CAUSE_CATEGORY:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_TOTAL_ACTIVITIES]' derivation='User' name='[usr:Calculation_TOTAL_ACTIVITIES:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view><breakdown value='auto' /></view>
            <mark class='Bar' />
            <encodings>
              <color column='[federated.1A2B3C4D].[none:ROOT_CAUSE_CATEGORY:nk]' />
            </encodings>
            <style>
              <style-rule element='mark'>
                <format attr='mark-labels-show' value='true' />
                <format attr='mark-labels-cull' value='true' />
              </style-rule>
            </style>
          </pane>
        </panes>
        <rows>[federated.1A2B3C4D].[usr:Calculation_TOTAL_ACTIVITIES:qk]</rows>
        <cols>[federated.1A2B3C4D].[none:ROOT_CAUSE_CATEGORY:nk]</cols>
      </table>
      <simple-id uuid='{AA00000C-0000-0000-0000-00000000000C}' />
    </worksheet>

    <!-- ── WORKSHEET 13: SLA BY DEPARTMENT ────────────────────────────── -->
    <worksheet name='SLA by Department'>
      <layout-options>
        <title><formatted-text><run fontsize='13'>SLA Compliance by Department</run></formatted-text></title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Service_Reliability_Support_DS' name='federated.1A2B3C4D' />
          </datasources>
          <datasource-dependencies datasource='federated.1A2B3C4D'>
            <column caption='Department Responsible' datatype='string' name='[DEPARTMENT_RESPONSIBLE]' role='dimension' type='nominal' />
            <column caption='SLA Compliance Rate' datatype='real' name='[Calculation_SLA_COMPLIANCE_RATE]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [SLA_MET] = TRUE THEN 1 ELSE 0 END) / COUNT([SUPPORT_ACTIVITY_ID])' />
            </column>
            <column-instance column='[DEPARTMENT_RESPONSIBLE]' derivation='None' name='[none:DEPARTMENT_RESPONSIBLE:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_SLA_COMPLIANCE_RATE]' derivation='User' name='[usr:Calculation_SLA_COMPLIANCE_RATE:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view><breakdown value='auto' /></view>
            <mark class='Bar' />
            <encodings>
              <color column='[federated.1A2B3C4D].[none:DEPARTMENT_RESPONSIBLE:nk]' />
            </encodings>
            <style>
