                <format attr='font-size' value='18' />
                <format attr='font-weight' value='bold' />
              </style-rule>
            </style>
          </pane>
        </panes>
        <rows>[federated.1a2b3c4d5e6f7g8h9i0j1k2l3m4n5o6p].[usr:Calculation_Total_Activities:qk] + [federated.1a2b3c4d5e6f7g8h9i0j1k2l3m4n5o6p].[usr:Calculation_Avg_Resolution_Time:qk] + [federated.1a2b3c4d5e6f7g8h9i0j1k2l3m4n5o6p].[usr:Calculation_SLA_Rate:qk] + [federated.1a2b3c4d5e6f7g8h9i0j1k2l3m4n5o6p].[usr:Calculation_FCR_Rate:qk]</rows>
