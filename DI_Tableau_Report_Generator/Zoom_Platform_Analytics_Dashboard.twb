        <rows>[federated.1A2B3C4D].[usr:Calculation_TOTAL_ACTIVITIES:qk]</rows>
        <cols>([federated.1A2B3C4D].[none:SUPPORT_CATEGORY:nk] / [federated.1A2B3C4D].[none:PLAN_TYPE:nk])</cols>
      </table>
      <simple-id uuid='{AA000008-0000-0000-0000-000000000008}' />
    </worksheet>

    <!-- ── WORKSHEET 9: FIRST RESPONSE BY CATEGORY ───────────────────── -->
    <worksheet name='First Response by Category'>
      <layout-options>
        <title><formatted-text><run fontsize='13'>First Response Time by Category</run></formatted-text></title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Service_Reliability_Support_DS' name='federated.1A2B3C4D' />
          </datasources>
          <datasource-dependencies datasource='federated.1A2B3C4D'>
            <column caption='Support Category' datatype='string' name='[SUPPORT_CATEGORY]' role='dimension' type='nominal' />
            <column caption='Average First Response Time' datatype='real' name='[Calculation_AVG_FIRST_RESPONSE]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([FIRST_RESPONSE_TIME_HOURS])' />
            </column>
            <column-instance column='[SUPPORT_CATEGORY]' derivation='None' name='[none:SUPPORT_CATEGORY:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_AVG_FIRST_RESPONSE]' derivation='User' name='[usr:Calculation_AVG_FIRST_RESPONSE:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view><breakdown value='auto' /></view>
            <mark class='Bar' />
            <style>
              <style-rule element='mark'>
                <format attr='mark-labels-show' value='true' />
                <format attr='mark-labels-cull' value='true' />
              </style-rule>
            </style>
          </pane>
        </panes>
        <rows>[federated.1A2B3C4D].[usr:Calculation_AVG_FIRST_RESPONSE:qk]</rows>
        <cols>[federated.1A2B3C4D].[none:SUPPORT_CATEGORY:nk]</cols>
      </table>
      <simple-id uuid='{AA000009-0000-0000-0000-000000000009}' />
    </worksheet>

    <!-- ── WORKSHEET 10: SATISFACTION BY COMPANY ─────────────────────── -->
    <worksheet name='Satisfaction by Company'>
      <layout-options>
        <title><formatted-text><run fontsize='13'>Customer Satisfaction by Company</run></formatted-text></title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Service_Reliability_Support_DS' name='federated.1A2B3C4D' />
          </datasources>
          <datasource-dependencies datasource='federated.1A2B3C4D'>
            <column caption='Company' datatype='string' name='[COMPANY]' role='dimension' type='nominal' />
            <column caption='Average Customer Satisfaction' datatype='real' name='[Calculation_AVG_SATISFACTION]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([CUSTOMER_SATISFACTION_SCORE])' />
            </column>
            <column-instance column='[COMPANY]' derivation='None' name='[none:COMPANY:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_AVG_SATISFACTION]' derivation='User' name='[usr:Calculation_AVG_SATISFACTION:qk]' pivot='key' type='quantitative' />
