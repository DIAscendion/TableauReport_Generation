            </properties>
          </object>
        </objects>
        <relationships>
          <!-- FACT ↔ DIM_DATE join -->
          <relationship>
            <expression op='='>
              <expression op='[DATE_KEY]' />
              <expression op='[DATE_KEY (DIM_DATE)]' />
            </expression>
            <first-end-point object-id='FACT_SUPPORT_ACTIVITY_obj' />
            <second-end-point object-id='DIM_DATE_obj' />
          </relationship>
          <!-- FACT ↔ DIM_SUPPORT_CATEGORY join -->
          <relationship>
            <expression op='='>
              <expression op='[SUPPORT_CATEGORY_KEY]' />
              <expression op='[SUPPORT_CATEGORY_KEY (DIM_SUPPORT_CATEGORY)]' />
            </expression>
            <first-end-point object-id='FACT_SUPPORT_ACTIVITY_obj' />
            <second-end-point object-id='DIM_SUPPORT_CATEGORY_obj' />
          </relationship>
          <!-- FACT ↔ DIM_USER join -->
          <relationship>
            <expression op='='>
              <expression op='[USER_KEY]' />
              <expression op='[USER_KEY (DIM_USER)]' />
            </expression>
            <first-end-point object-id='FACT_SUPPORT_ACTIVITY_obj' />
            <second-end-point object-id='DIM_USER_obj' />
          </relationship>
        </relationships>
      </_.fcp.ObjectModelEncapsulateLegacy.true...object-graph>

