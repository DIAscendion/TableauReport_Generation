  <!--  SECTION 4: WORKSHEETS                                             -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <worksheets>

    <!-- ── WORKSHEET 1: KPI SCORECARD ──────────────────────────────── -->
    <worksheet name='Service KPIs'>
      <layout-options>
        <title><formatted-text><run fontsize='14'>Key Performance Indicators</run></formatted-text></title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Service_Reliability_Support_DS' name='federated.1A2B3C4D' />
          </datasources>
          <datasource-dependencies datasource='federated.1A2B3C4D'>
            <column caption='Total Activities' datatype='integer' name='[Calculation_TOTAL_ACTIVITIES]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT([SUPPORT_ACTIVITY_ID])' />
            </column>
            <column caption='Average Resolution Time' datatype='real' name='[Calculation_AVG_RESOLUTION_TIME]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([RESOLUTION_TIME_HOURS])' />
            </column>
            <column caption='SLA Compliance Rate' datatype='real' name='[Calculation_SLA_COMPLIANCE_RATE]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [SLA_MET] = TRUE THEN 1 ELSE 0 END) / COUNT([SUPPORT_ACTIVITY_ID])' />
            </column>
            <column caption='First Contact Resolution Rate' datatype='real' name='[Calculation_FCR_RATE]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [FIRST_CONTACT_RESOLUTION_FLAG] = TRUE THEN 1 ELSE 0 END) / COUNT([SUPPORT_ACTIVITY_ID])' />
            </column>
            <column-instance column='[Calculation_TOTAL_ACTIVITIES]' derivation='User' name='[usr:Calculation_TOTAL_ACTIVITIES:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_AVG_RESOLUTION_TIME]' derivation='User' name='[usr:Calculation_AVG_RESOLUTION_TIME:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_SLA_COMPLIANCE_RATE]' derivation='User' name='[usr:Calculation_SLA_COMPLIANCE_RATE:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_FCR_RATE]' derivation='User' name='[usr:Calculation_FCR_RATE:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view><breakdown value='auto' /></view>
            <mark class='Text' />
            <encodings>
              <text column='[federated.1A2B3C4D].[usr:Calculation_TOTAL_ACTIVITIES:qk]' />
            </encodings>
            <style>
              <style-rule element='mark'>
                <format attr='font-size' value='18' />
              </style-rule>
            </style>
          </pane>
        </panes>
        <rows>[federated.1A2B3C4D].[usr:Calculation_TOTAL_ACTIVITIES:qk] + [federated.1A2B3C4D].[usr:Calculation_AVG_RESOLUTION_TIME:qk] + [federated.1A2B3C4D].[usr:Calculation_SLA_COMPLIANCE_RATE:qk] + [federated.1A2B3C4D].[usr:Calculation_FCR_RATE:qk]</rows>
        <cols />
      </table>
      <simple-id uuid='{AA000001-0000-0000-0000-000000000001}' />
    </worksheet>

