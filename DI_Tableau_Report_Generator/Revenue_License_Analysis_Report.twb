      <aliases enabled='yes' />
      
      <!-- Calculated Fields for KPIs -->
      <column caption='Monthly Recurring Revenue' datatype='real' name='[Calculation_MRR]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([MRR_IMPACT])' />
      </column>
      
      <column caption='Annual Recurring Revenue' datatype='real' name='[Calculation_ARR]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([ARR_IMPACT])' />
      </column>
      
      <column caption='Total Revenue' datatype='real' name='[Calculation_Total_Revenue]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([NET_AMOUNT])' />
      </column>
      
      <column caption='MRR Growth Rate' datatype='real' name='[Calculation_MRR_Growth_Rate]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([MRR_IMPACT]) - LOOKUP(SUM([MRR_IMPACT]), -1)) / LOOKUP(SUM([MRR_IMPACT]), -1)' />
      </column>
      
      <column caption='License Utilization Rate' datatype='real' name='[Calculation_License_Utilization]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([USER_DIM_ID]) / SUM([MAX_PARTICIPANTS])' />
      </column>
      
      <column caption='Average Customer Lifetime Value' datatype='real' name='[Calculation_Avg_CLV]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([CUSTOMER_LIFETIME_VALUE])' />
      </column>
      
      <column caption='Average Churn Risk Score' datatype='real' name='[Calculation_Avg_Churn_Risk]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([CHURN_RISK_SCORE])' />
      </column>
      
      <column caption='Revenue Percentage by Plan' datatype='real' name='[Calculation_Revenue_Percentage]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([NET_AMOUNT]) / TOTAL(SUM([NET_AMOUNT]))' />
      </column>
      
      <column caption='License Duration Days' datatype='integer' name='[Calculation_License_Duration]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&quot;day&quot;, [EFFECTIVE_START_DATE], [EFFECTIVE_END_DATE])' />
      </column>
      
      <!-- Dimension Columns -->
      <column caption='License Type' datatype='string' name='[LICENSE_TYPE]' role='dimension' type='nominal' />
      <column caption='License Category' datatype='string' name='[LICENSE_CATEGORY]' role='dimension' type='nominal' />
      <column caption='Plan Type' datatype='string' name='[PLAN_TYPE]' role='dimension' type='nominal' />
      <column caption='Geographic Region' datatype='string' name='[GEOGRAPHIC_REGION]' role='dimension' type='nominal' />
      <column caption='Company' datatype='string' name='[COMPANY]' role='dimension' type='nominal' />
      <column caption='Event Type' datatype='string' name='[EVENT_TYPE]' role='dimension' type='nominal' />
      <column caption='Revenue Type' datatype='string' name='[REVENUE_TYPE]' role='dimension' type='nominal' />
      <column caption='Currency Code' datatype='string' name='[CURRENCY_CODE]' role='dimension' type='nominal' />
      <column caption='Month Name' datatype='string' name='[MONTH_NAME]' role='dimension' type='nominal' />
      <column caption='Year' datatype='integer' name='[YEAR]' role='dimension' type='ordinal' />
      <column caption='Transaction Date' datatype='date' name='[TRANSACTION_DATE]' role='dimension' type='ordinal' />
      <column caption='License Start Date' datatype='date' name='[EFFECTIVE_START_DATE]' role='dimension' type='ordinal' />
      <column caption='License End Date' datatype='date' name='[EFFECTIVE_END_DATE]' role='dimension' type='ordinal' />
      
