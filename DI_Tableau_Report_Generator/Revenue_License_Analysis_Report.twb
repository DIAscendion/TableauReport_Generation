      <aliases enabled='yes' />
      <column caption='Monthly Recurring Revenue' datatype='real' name='[Calculation_MRR]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([MRR_IMPACT])' />
      </column>
      <column caption='Total Revenue' datatype='real' name='[Calculation_Total_Revenue]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([AMOUNT])' />
      </column>
      <column caption='License Utilization Rate' datatype='real' name='[Calculation_License_Utilization_Rate]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([ASSIGNED_USER_ID]) / COUNTD([LICENSE_ID])' />
      </column>
      <column caption='Average Revenue Per User' datatype='real' name='[Calculation_ARPU]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([AMOUNT]) / COUNTD([USER_ID])' />
      </column>
      <column caption='Customer Lifetime Value' datatype='real' name='[Calculation_CLV]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([AMOUNT]) * 12 / COUNTD([USER_ID])' />
      </column>
      <column caption='Churn Rate' datatype='real' name='[Calculation_Churn_Rate]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [EVENT_TYPE] = "Cancellation" THEN 1 ELSE 0 END) / COUNTD([USER_ID])' />
      </column>
      <column caption='License Expiring Soon' datatype='integer' name='[Calculation_License_Expiring_Soon]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF DATEDIFF("day", TODAY(), [EFFECTIVE_END_DATE]) &lt;= 30 THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Total Licenses' datatype='integer' name='[Calculation_Total_Licenses]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([LICENSE_ID])' />
      </column>
      <column caption='Active Licenses' datatype='integer' name='[Calculation_Active_Licenses]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [LICENSE_STATUS] = "Active" THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Revenue Growth Rate' datatype='real' name='[Calculation_Revenue_Growth_Rate]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([AMOUNT]) - LOOKUP(SUM([AMOUNT]), -1)) / LOOKUP(SUM([AMOUNT]), -1)' />
      </column>
      <column caption='Billing Event Id' datatype='integer' name='[BILLING_EVENT_ID]' role='dimension' type='ordinal' />
      <column caption='User Id' datatype='string' name='[USER_ID]' role='dimension' type='nominal' />
      <column caption='Event Date' datatype='date' name='[EVENT_DATE]' role='dimension' type='ordinal' />
      <column caption='Event Type' datatype='string' name='[EVENT_TYPE]' role='dimension' type='nominal' />
      <column caption='Amount' datatype='real' name='[AMOUNT]' role='measure' type='quantitative' />
      <column caption='Currency' datatype='string' name='[CURRENCY]' role='dimension' type='nominal' />
      <column caption='Mrr Impact' datatype='real' name='[MRR_IMPACT]' role='measure' type='quantitative' />
      <column caption='License Usage Id' datatype='integer' name='[LICENSE_USAGE_ID]' role='dimension' type='ordinal' />
      <column caption='License Id' datatype='string' name='[LICENSE_ID]' role='dimension' type='nominal' />
      <column caption='Assigned User Id' datatype='string' name='[ASSIGNED_USER_ID]' role='dimension' type='nominal' />
      <column caption='Usage Date' datatype='date' name='[USAGE_DATE]' role='dimension' type='ordinal' />
      <column caption='Utilization Hours' datatype='real' name='[UTILIZATION_HOURS]' role='measure' type='quantitative' />
      <column caption='Date Key (Dim Date)' datatype='date' name='[DATE_KEY (DIM_DATE)]' role='dimension' type='ordinal' />
      <column caption='Date Value' datatype='date' name='[DATE_VALUE]' role='dimension' type='ordinal' />
      <column caption='Month Name' datatype='string' name='[MONTH_NAME]' role='dimension' type='nominal' />
      <column caption='Year' datatype='integer' name='[YEAR]' role='dimension' type='quantitative' />
      <column caption='Quarter' datatype='integer' name='[QUARTER]' role='dimension' type='quantitative' />
      <column caption='Day Name' datatype='string' name='[DAY_NAME]' role='dimension' type='nominal' />
      <column caption='User Key (Dim User)' datatype='string' name='[USER_KEY (DIM_USER)]' role='dimension' type='nominal' />
      <column caption='User Id (Dim User)' datatype='string' name='[USER_ID (DIM_USER)]' role='dimension' type='nominal' />
      <column caption='User Name' datatype='string' name='[USER_NAME]' role='dimension' type='nominal' />
      <column caption='Company' datatype='string' name='[COMPANY]' role='dimension' type='nominal' />
