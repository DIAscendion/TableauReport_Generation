      </connection>
      
      <!-- Calculated Fields -->
      <column caption='Monthly Recurring Revenue' datatype='real' name='[Calculation_MRR]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([MRR_IMPACT])' />
      </column>
      <column caption='Annual Recurring Revenue' datatype='real' name='[Calculation_ARR]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([ARR_IMPACT])' />
      </column>
      <column caption='Total Revenue' datatype='real' name='[Calculation_Total_Revenue]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([NET_AMOUNT])' />
      </column>
      <column caption='Revenue Growth Rate' datatype='real' name='[Calculation_Revenue_Growth_Rate]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([NET_AMOUNT]) - LOOKUP(SUM([NET_AMOUNT]), -1)) / LOOKUP(SUM([NET_AMOUNT]), -1)' />
      </column>
      <column caption='License Utilization Rate' datatype='real' name='[Calculation_License_Utilization_Rate]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([USER_DIM_ID]) / SUM([MAX_PARTICIPANTS])' />
      </column>
      <column caption='Average Customer Lifetime Value' datatype='real' name='[Calculation_Avg_CLV]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([CUSTOMER_LIFETIME_VALUE])' />
      </column>
      <column caption='Churn Risk Segment' datatype='string' name='[Calculation_Churn_Risk_Segment]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [CHURN_RISK_SCORE] &gt; 7 THEN &quot;High Risk&quot; ELSEIF [CHURN_RISK_SCORE] &gt; 4 THEN &quot;Medium Risk&quot; ELSE &quot;Low Risk&quot; END' />
      </column>
      <column caption='License Duration Days' datatype='integer' name='[Calculation_License_Duration]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [EFFECTIVE_START_DATE], [EFFECTIVE_END_DATE])' />
      </column>
      
      <!-- Column Instances -->
      <column-instance column='[DATE_VALUE]' derivation='Month' name='[mn:DATE_VALUE:ok]' pivot='key' type='ordinal' />
