      <aliases enabled='yes' />
      
      <!-- Calculated Fields for KPIs and Metrics -->
      <column caption='Monthly Recurring Revenue' datatype='real' name='[Calculation_MRR]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([MRR_IMPACT])' />
      </column>
      <column caption='Annual Recurring Revenue' datatype='real' name='[Calculation_ARR]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([ARR_IMPACT])' />
      </column>
      <column caption='Total Revenue' datatype='real' name='[Calculation_Total_Revenue]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([NET_AMOUNT])' />
      </column>
      <column caption='Average Customer Lifetime Value' datatype='real' name='[Calculation_Avg_CLV]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([CUSTOMER_LIFETIME_VALUE])' />
      </column>
      <column caption='License Utilization Rate' datatype='real' name='[Calculation_License_Utilization_Rate]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [IS_CURRENT_RECORD] = TRUE THEN 1 END) / COUNT([LICENSE_ID])' />
      </column>
      <column caption='Churn Risk Rate' datatype='real' name='[Calculation_Churn_Risk_Rate]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([CHURN_RISK_SCORE])' />
      </column>
      <column caption='Revenue Growth Rate' datatype='real' name='[Calculation_Revenue_Growth_Rate]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([NET_AMOUNT]) - LOOKUP(SUM([NET_AMOUNT]), -1)) / LOOKUP(SUM([NET_AMOUNT]), -1)' />
      </column>
      <column caption='License Count' datatype='integer' name='[Calculation_License_Count]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([LICENSE_ID])' />
      </column>
      <column caption='Revenue Per Customer' datatype='real' name='[Calculation_Revenue_Per_Customer]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([NET_AMOUNT]) / COUNTD([USER_DIM_ID])' />
      </column>
      <column caption='Total Billing Events' datatype='integer' name='[Calculation_Total_Billing_Events]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([BILLING_EVENT_ID])' />
      </column>
      
      <!-- Dimension Columns -->
      <column caption='Event Type' datatype='string' name='[EVENT_TYPE]' role='dimension' type='nominal' />
      <column caption='Revenue Type' datatype='string' name='[REVENUE_TYPE]' role='dimension' type='nominal' />
      <column caption='Payment Method' datatype='string' name='[PAYMENT_METHOD]' role='dimension' type='nominal' />
