  <worksheets>
    <worksheet name='Revenue KPIs'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontsize='14'>Revenue &amp; License KPIs</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Revenue_License_Analysis_DS' name='federated.3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f' />
          </datasources>
          <datasource-dependencies datasource='federated.3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f'>
            <column caption='Monthly Recurring Revenue' datatype='real' name='[Calculation_MRR]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([MRR_IMPACT])' />
            </column>
            <column caption='Total Revenue' datatype='real' name='[Calculation_Total_Revenue]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([AMOUNT])' />
            </column>
            <column caption='License Utilization Rate' datatype='real' name='[Calculation_License_Utilization_Rate]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([ASSIGNED_USER_ID]) / COUNTD([LICENSE_ID])' />
            </column>
            <column caption='Average Revenue Per User' datatype='real' name='[Calculation_ARPU]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([AMOUNT]) / COUNTD([USER_ID])' />
            </column>
            <column-instance column='[Calculation_MRR]' derivation='User' name='[usr:Calculation_MRR:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_Total_Revenue]' derivation='User' name='[usr:Calculation_Total_Revenue:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_License_Utilization_Rate]' derivation='User' name='[usr:Calculation_License_Utilization_Rate:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_ARPU]' derivation='User' name='[usr:Calculation_ARPU:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
