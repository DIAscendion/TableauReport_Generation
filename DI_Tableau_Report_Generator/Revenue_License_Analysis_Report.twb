              <calculation class='tableau' formula='SUM([MRR_IMPACT])' />
            </column>
            <column caption='Transaction Date' datatype='date' name='[TRANSACTION_DATE]' role='dimension' type='ordinal' />
            <column caption='License Type' datatype='string' name='[LICENSE_TYPE]' role='dimension' type='nominal' />
            <column-instance column='[TRANSACTION_DATE]' derivation='None' name='[none:TRANSACTION_DATE:ok]' pivot='key' type='ordinal' />
            <column-instance column='[LICENSE_TYPE]' derivation='None' name='[none:LICENSE_TYPE:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_MRR]' derivation='User' name='[usr:Calculation_MRR:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Line' />
            <encodings>
              <color column='[federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a].[none:LICENSE_TYPE:nk]' />
            </encodings>
          </pane>
        </panes>
        <rows>[federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a].[usr:Calculation_MRR:qk]</rows>
        <cols>[federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a].[none:TRANSACTION_DATE:ok]</cols>
      </table>
      <simple-id uuid='{B4C5D6E7-F8A9-B0C1-D2E3-F4A5B6C7D8E9}' />
    </worksheet>
    
    <!-- Revenue by Plan Type Stacked Bar Chart -->
    <worksheet name='Revenue by Plan Type'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontsize='12'>Revenue Distribution by Plan Type</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Revenue_License_Analysis_DS' name='federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a' />
          </datasources>
          <datasource-dependencies datasource='federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a'>
            <column caption='Total Revenue' datatype='real' name='[Calculation_Total_Revenue]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([NET_AMOUNT])' />
            </column>
            <column caption='Plan Type' datatype='string' name='[PLAN_TYPE]' role='dimension' type='nominal' />
            <column caption='Month Name' datatype='string' name='[MONTH_NAME]' role='dimension' type='nominal' />
            <column caption='Year' datatype='integer' name='[YEAR]' role='dimension' type='ordinal' />
            <column-instance column='[PLAN_TYPE]' derivation='None' name='[none:PLAN_TYPE:nk]' pivot='key' type='nominal' />
            <column-instance column='[MONTH_NAME]' derivation='None' name='[none:MONTH_NAME:nk]' pivot='key' type='nominal' />
            <column-instance column='[YEAR]' derivation='None' name='[none:YEAR:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Calculation_Total_Revenue]' derivation='User' name='[usr:Calculation_Total_Revenue:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Area' />
            <encodings>
              <color column='[federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a].[none:PLAN_TYPE:nk]' />
            </encodings>
          </pane>
        </panes>
        <rows>[federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a].[usr:Calculation_Total_Revenue:qk]</rows>
        <cols>([federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a].[none:YEAR:ok] / [federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a].[none:MONTH_NAME:nk])</cols>
      </table>
      <simple-id uuid='{C5D6E7F8-A9B0-C1D2-E3F4-A5B6C7D8E9F0}' />
    </worksheet>
    
    <!-- License Utilization Gantt Chart -->
    <worksheet name='License Utilization Timeline'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontsize='12'>License Utilization Timeline</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Revenue_License_Analysis_DS' name='federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a' />
          </datasources>
          <datasource-dependencies datasource='federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a'>
            <column caption='License Utilization Rate' datatype='real' name='[Calculation_License_Utilization]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([USER_DIM_ID_REVENUE]) / SUM([MAX_PARTICIPANTS])' />
            </column>
            <column caption='License Duration Days' datatype='integer' name='[Calculation_License_Duration]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEDIFF(&quot;day&quot;, [EFFECTIVE_START_DATE], [EFFECTIVE_END_DATE])' />
            </column>
            <column caption='License Type' datatype='string' name='[LICENSE_TYPE]' role='dimension' type='nominal' />
            <column caption='Effective Start Date' datatype='date' name='[EFFECTIVE_START_DATE]' role='dimension' type='ordinal' />
            <column caption='Effective End Date' datatype='date' name='[EFFECTIVE_END_DATE]' role='dimension' type='ordinal' />
            <column-instance column='[LICENSE_TYPE]' derivation='None' name='[none:LICENSE_TYPE:nk]' pivot='key' type='nominal' />
            <column-instance column='[EFFECTIVE_START_DATE]' derivation='None' name='[none:EFFECTIVE_START_DATE:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Calculation_License_Duration]' derivation='User' name='[usr:Calculation_License_Duration:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_License_Utilization]' derivation='User' name='[usr:Calculation_License_Utilization:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Gantt' />
            <encodings>
              <color column='[federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a].[usr:Calculation_License_Utilization:qk]' />
              <size column='[federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a].[usr:Calculation_License_Duration:qk]' />
            </encodings>
          </pane>
        </panes>
        <rows>[federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a].[none:LICENSE_TYPE:nk]</rows>
        <cols>[federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a].[none:EFFECTIVE_START_DATE:ok]</cols>
      </table>
      <simple-id uuid='{D6E7F8A9-B0C1-D2E3-F4A5-B6C7D8E9F0A1}' />
    </worksheet>
    
    <!-- Customer Lifetime Value vs Churn Risk Scatter Plot -->
    <worksheet name='CLV vs Churn Risk'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontsize='12'>Customer Lifetime Value vs Churn Risk</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Revenue_License_Analysis_DS' name='federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a' />
          </datasources>
          <datasource-dependencies datasource='federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a'>
            <column caption='Average Customer Lifetime Value' datatype='real' name='[Calculation_Avg_CLV]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([CUSTOMER_LIFETIME_VALUE])' />
            </column>
            <column caption='Average Churn Risk Score' datatype='real' name='[Calculation_Avg_Churn_Risk]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([CHURN_RISK_SCORE])' />
            </column>
            <column caption='Plan Type' datatype='string' name='[PLAN_TYPE]' role='dimension' type='nominal' />
            <column caption='Total Revenue' datatype='real' name='[Calculation_Total_Revenue]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([NET_AMOUNT])' />
            </column>
            <column-instance column='[PLAN_TYPE]' derivation='None' name='[none:PLAN_TYPE:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_Avg_CLV]' derivation='User' name='[usr:Calculation_Avg_CLV:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_Avg_Churn_Risk]' derivation='User' name='[usr:Calculation_Avg_Churn_Risk:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_Total_Revenue]' derivation='User' name='[usr:Calculation_Total_Revenue:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Circle' />
            <encodings>
              <color column='[federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a].[none:PLAN_TYPE:nk]' />
              <size column='[federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a].[usr:Calculation_Total_Revenue:qk]' />
            </encodings>
          </pane>
        </panes>
        <rows>[federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a].[usr:Calculation_Avg_CLV:qk]</rows>
        <cols>[federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a].[usr:Calculation_Avg_Churn_Risk:qk]</cols>
      </table>
      <simple-id uuid='{E7F8A9B0-C1D2-E3F4-A5B6-C7D8E9F0A1B2}' />
    </worksheet>
    
    <!-- Geographic Revenue Distribution -->
    <worksheet name='Geographic Revenue Distribution'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontsize='12'>Revenue Distribution by Geographic Region</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Revenue_License_Analysis_DS' name='federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a' />
          </datasources>
          <datasource-dependencies datasource='federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a'>
            <column caption='Total Revenue' datatype='real' name='[Calculation_Total_Revenue]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([NET_AMOUNT])' />
            </column>
            <column caption='Geographic Region' datatype='string' name='[GEOGRAPHIC_REGION]' role='dimension' type='nominal' />
            <column-instance column='[GEOGRAPHIC_REGION]' derivation='None' name='[none:GEOGRAPHIC_REGION:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_Total_Revenue]' derivation='User' name='[usr:Calculation_Total_Revenue:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Square' />
            <encodings>
              <color column='[federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a].[usr:Calculation_Total_Revenue:qk]' />
              <size column='[federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a].[usr:Calculation_Total_Revenue:qk]' />
            </encodings>
          </pane>
        </panes>
        <rows>[federated.3cde4f5a6b7c8d9e0f1a2b3c4d5e6f7a].[none:GEOGRAPHIC_REGION:nk]</rows>
        <cols />
      </table>
      <simple-id uuid='{F8A9B0C1-D2E3-F4A5-B6C7-D8E9F0A1B2C3}' />
    </worksheet>
  </worksheets>
  
