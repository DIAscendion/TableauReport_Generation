              <size column='[federated.2b3c4d5e6f7g8h9i0j1k2l3m4n5o6p7].[usr:Calculation_Total_Tickets:qk]' />
            </encodings>
            <style>
              <style-rule element='mark'>
                <format attr='mark-labels-show' value='true' />
              </style-rule>
            </style>
          </pane>
        </panes>
        <rows /><cols />
      </table>
      <simple-id uuid='{BB000004-0000-0000-0000-000000000004}' />
