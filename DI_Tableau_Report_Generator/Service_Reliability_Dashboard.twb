        <cols>([federated.1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d].[none:SUPPORT_SUBCATEGORY:nk] / [federated.1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d].[none:SUPPORT_CATEGORY:nk])</cols>
      </table>
