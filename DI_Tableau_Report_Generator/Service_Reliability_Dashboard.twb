      <column caption='Account Type' datatype='string' name='[ACCOUNT_TYPE]' role='dimension' type='nominal' />
      <column caption='Active Work Time Hours' datatype='integer' name='[ACTIVE_WORK_TIME_HOURS]' role='measure' type='quantitative' />
      <column caption='Agent Interactions Count' datatype='integer' name='[AGENT_INTERACTIONS_COUNT]' role='measure' type='quantitative' />
      <column caption='Common Resolution Steps' datatype='string' name='[COMMON_RESOLUTION_STEPS]' role='dimension' type='nominal' />
      <column caption='Company' datatype='string' name='[COMPANY]' role='dimension' type='nominal' />
      <column caption='Cost To Resolve' datatype='integer' name='[COST_TO_RESOLVE]' role='measure' type='quantitative' />
      <column caption='Customer Impact Level' datatype='string' name='[CUSTOMER_IMPACT_LEVEL]' role='dimension' type='nominal' />
      <column caption='Customer Interactions Count' datatype='integer' name='[CUSTOMER_INTERACTIONS_COUNT]' role='measure' type='quantitative' />
      <column caption='Customer Satisfaction Score' datatype='integer' name='[CUSTOMER_SATISFACTION_SCORE]' role='measure' type='quantitative' />
      <column caption='Customer Wait Time Hours' datatype='integer' name='[CUSTOMER_WAIT_TIME_HOURS]' role='measure' type='quantitative' />
      <column caption='Average Resolution Time' datatype='real' name='[Calculation_AVG_RESOLUTION_TIME]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([RESOLUTION_TIME_HOURS])' />
      </column>
      <column caption='Total Support Activities' datatype='integer' name='[Calculation_TOTAL_ACTIVITIES]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([SUPPORT_ACTIVITY_ID])' />
      </column>
      <column caption='Average Customer Satisfaction' datatype='real' name='[Calculation_AVG_SATISFACTION]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([CUSTOMER_SATISFACTION_SCORE])' />
      </column>
      <column caption='SLA Compliance Rate' datatype='real' name='[Calculation_SLA_COMPLIANCE]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [SLA_MET] = TRUE THEN 1 ELSE 0 END) / COUNT([SUPPORT_ACTIVITY_ID])' />
      </column>
      <column caption='First Contact Resolution Rate' datatype='real' name='[Calculation_FCR_RATE]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [FIRST_CONTACT_RESOLUTION_FLAG] = TRUE THEN 1 ELSE 0 END) / COUNT([SUPPORT_ACTIVITY_ID])' />
      </column>
      <column caption='Number of Users' datatype='integer' name='[Calculation_USER_COUNT]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([USER_ID])' />
      </column>
