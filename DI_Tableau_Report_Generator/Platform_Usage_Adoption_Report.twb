            <encodings><color column='[federated.1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d].[usr:Calculation_FEATURE_ADOPTION_RATE:qk]' /></encodings>
            <style><style-rule element='mark'><format attr='mark-labels-show' value='true' /></style-rule></style>
          </pane>
        </panes>
        <rows>[federated.1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d].[none:FEATURE_NAME:nk]</rows>
        <cols>[federated.1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d].[none:FEATURE_CATEGORY:nk]</cols>
      </table>
